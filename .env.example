# ─── Kite Connect (Zerodha) ───────────────────────────────────────────────────
# ⚠️  NOT required for paper trading — paper trades go to Supabase only.
# Only needed for real-money (mode: "real") broker orders.
#
# SANDBOX (free, no real money):
#   1. Go to https://developers.kite.trade → create an app
#   2. Set redirect URL to http://localhost:3000/api/broker/callback
#   3. Use api_key + api_secret from the developer console
#   4. Login URL: https://kite.zerodha.com/connect/login?v=3&api_key=YOUR_KEY
#
# Paper trading works with KITE_API_KEY left blank.
KITE_API_KEY=zld3qupmijnt7zj2
KITE_API_SECRET=gzoiwad3o167r5qxbxi3e6neurwd723r
KITE_REDIRECT_URL=http://localhost:3000/api/broker/callback

# Trading mode: "paper" (default, safe) or "real" (live broker orders)
# This guards the executor — paper mode never calls Kite even if keys are set.
TRADE_MODE=paper

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Socket.IO server ─────────────────────────────────────────────────────────
